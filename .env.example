# Copy to .env and fill in. .env is git-ignored — never commit real values.

# --- Kaggle API (kaggle.com -> Account -> Create New Token) ---
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key

# --- GCP ---
# Use the project on matirvazques@gmail.com. Region MUST be US for GCS/BQ Always Free.
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1
GCS_BUCKET=credit-risk-cockpit-raw
BQ_DATASET=raw
BQ_DBT_DATASET=analytics
BQ_LOCATION=US

# --- Source dataset (LendingClub, CC0) ---
# File is stored gzipped in the dataset; BigQuery loads gzipped CSV directly.
KAGGLE_DATASET=wordsforthewise/lending-club
KAGGLE_FILE=accepted_2007_to_2018Q4.csv.gz
BQ_RAW_TABLE=lending_club_accepted

# --- Copilot (Google AI Studio, free tier — https://aistudio.google.com/apikey) ---
# API-key auth, no billing attached: the free-tier daily quota is a hard $0 ceiling.
GEMINI_API_KEY=your_ai_studio_api_key
# Optional override; defaults to gemini-flash-lite-latest.
# COPILOT_MODEL=gemini-flash-lite-latest
